{
  "multipart": [
    {
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/core"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/extension"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/extension",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/extension",
        "y": 180
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/extension",
        "y": 270
      }
    },
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/extension",
        "x": 270
      }
    },
    {
      "when": {
        "down": "true"
      },
      "apply": {
        "model": "fastpipes:block/pipe/energy/elite/extension",
        "x": 90
      }
    }
  ]
}